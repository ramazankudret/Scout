# Scout Backend Environment Configuration
# Copy this file to .env and adjust values

# Application
APP_NAME=Scout
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development

# API
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000"]

# Database
DATABASE_URL=postgresql+asyncpg://scout:secure_password@localhost:5432/scout_db

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM Configuration
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Security (CHANGE IN PRODUCTION!)
SECRET_KEY=dev-secret-key-change-in-production

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=console
