# Scout Backend Environment Configuration
# 1) Bu dosyayi .env olarak kopyalayin (backend/.env)
# 2) PostgreSQL calismali; kullanici ve veritabani olusturun:
#    create user scout with password 'secure_password';
#    create database scout_db owner scout;
# 3) Uygulamayi backend/ klasorunden calistirin ki .env okunsun

# Application
APP_NAME=Scout
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development

# API
API_PREFIX=/api/v1
# Frontend adresi; 192.168.x.x:3000 ile açıyorsan onu da ekle (JSON array)
# CORS_ORIGINS=["http://localhost:3000","http://192.168.1.11:3000"]
CORS_ORIGINS=["http://localhost:3000"]

# Database
DATABASE_URL=postgresql+asyncpg://scout:secure_password@localhost:5432/scout_db

# Redis
REDIS_URL=redis://localhost:6379/0

# LLM Configuration
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Lesson Model (learn verisiyle eğitilecek model; boş = RAG kullan)
# OLLAMA_LESSON_MODEL=scout-lessons:latest
LESSON_MODEL_BASE=nemotron-mini:4b
LESSON_EXPORT_DIR=data/lesson_export
LESSON_MIN_SAMPLES_FOR_TRAINING=100
LESSON_MODEL_OUTPUT_DIR=data/lesson_model_output

# Security (CHANGE IN PRODUCTION!)
SECRET_KEY=dev-secret-key-change-in-production

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=console
